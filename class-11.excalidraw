    {
      "id": "VK7mV49_Pciow2-yVHXZw",
      "type": "text",
      "x": -760.0040798877719,
      "y": 201.07721412232115,
      "width": 831.5994873046875,
      "height": 855,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
